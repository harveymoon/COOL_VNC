{
  "name": "cool-vnc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n vite,proxy -c blue,green \"vite\" \"node server/proxy.mjs\"",
    "dev:ui": "vite",
    "dev:proxy": "node server/proxy.mjs",
    "build": "tsc && vite build",
    "preview": "concurrently -k -n vite,proxy -c blue,green \"vite preview\" \"node server/proxy.mjs\"",
    "electron:dev": "concurrently -k -n vite,electron -c blue,magenta \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "pack": "npm run build && electron-builder",
    "pack:win": "npm run build && electron-builder --win",
    "pack:dir": "npm run build && electron-builder --dir",
    "pack:portable": "npm run build && electron-packager . cool-vnc --platform=win32 --arch=x64 --out=release --overwrite --asar --prune=true --ignore=\"^/(release|data|\\.git|src|electron/.+\\.map)\""
  },
  "dependencies": {
    "@novnc/novnc": "^1.5.0",
    "des.js": "^1.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "concurrently": "^9.0.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.coolvnc.app",
    "productName": "cool-vnc",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "dist/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.markdown,.DS_Store,LICENSE,LICENSE.txt}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples,docs,doc}",
      "!**/node_modules/.cache",
      "!**/{.git,.github,.vscode,.idea,.editorconfig}"
    ],
    "asarUnpack": [
      "server/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "category": "Network"
    }
  }
}
